PORT=3000
NODE_ENV=production

# JWT Secret (เปลี่ยนเป็น random string ยาวๆ)
JWT_SECRET=your-super-secret-jwt-key-change-this

# LINE Bot (optional - ใส่เมื่อมี token)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Gemini AI
GEMINI_API_KEY=

# Database path (Railway จะเซ็ตให้อัตโนมัติ)
DATABASE_PATH=./data/database.sqlite

# CORS - URL ของ frontend
FRONTEND_URL=https://app.meowchat.store
